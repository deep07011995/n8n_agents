    {
      "parameters": {
        "jsCode": "const jobs = $json.data || $json.items || [];\n\nlet html = `\n<h2>🚀 AI Curated Jobs for Deepanshu</h2>\n<hr>\n`;\n\nfor (const job of jobs) {\n  html += `\n  <h3>${job.title}</h3>\n\n  <b>Company:</b> ${job.company}<br>\n  <b>Location:</b> ${job.location}<br>\n  <b>Score:</b> ${job.score}/100<br><br>\n\n  <b>Why Match:</b><br>\n  ${job.reason}<br><br>\n\n  <a href=\"${job.job_url}\">\n    Apply on Naukri\n  </a>\n\n  <hr>\n  `;\n}\n\nreturn [{\n  json: {\n    html\n  }\n}];"
      },
